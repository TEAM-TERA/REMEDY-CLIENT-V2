# Copy to `.env` and fill in. `.env` is gitignored — never commit real keys.
# Spotify (Developer Dashboard) — used in-app for login-free Client Credentials search.
EXPO_PUBLIC_SPOTIFY_CLIENT_ID=your_spotify_client_id
EXPO_PUBLIC_SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
# Google Maps SDK key (restrict by bundle id com.remedy.app) — used by app.config.js.
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
# Optional backend base url
# EXPO_PUBLIC_API_BASE_URL=https://api.remedy.example.com
