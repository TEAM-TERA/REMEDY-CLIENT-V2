# Copy to `.env` and fill in. `.env` is gitignored — never commit real keys.

# Google Maps SDK key (restrict by bundle id com.remedy.app) — used by app.config.js.
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Backend (REMEDY-BACK-V3) base URL. Leave unset to use the per-platform default
# (iOS sim → http://localhost:4000/api/v1, Android emulator → http://10.0.2.2:4000/api/v1).
# Set to your dev machine's LAN IP to test on a physical device.
# Spotify search/metadata is served by the backend, so NO Spotify secret is needed in the app.
# EXPO_PUBLIC_API_BASE_URL=http://localhost:4000/api/v1
